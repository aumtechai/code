{
  "version": 2,
  "name": "aura-stable-final",
  "trailingSlash": false,
  "buildCommand": "cd 3_code/frontend && npm install && npm run build",
  "outputDirectory": "3_code/frontend/dist",
  "installCommand": "echo skip-root-install",
  "functions": {
    "api/core/index.py": {
      "maxDuration": 300
    },
    "api/swarm/index.py": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/swarm/:path*", "destination": "/api/swarm/index.py" },
    { "source": "/api/:path*",       "destination": "/api/core/index.py" },
    { "source": "/((?!api/).*)",     "destination": "/index.html" }
  ]
}
