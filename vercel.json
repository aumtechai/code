{
  "version": 2,
  "name": "aura-stable-final",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/swarm/(.*)",
      "dest": "api/swarm/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/core/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "/index.html"
    }
  ]
}
