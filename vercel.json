{
  "version": 2,
  "name": "aura-stable-final",
  "trailingSlash": false,
  "functions": {
    "api/core/index.py": {
      "maxDuration": 300
    },
    "api/swarm/index.py": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/swarm/:path*", "destination": "/api/swarm/index.py" },
    { "source": "/api/:path*",       "destination": "/api/core/index.py" },
    { "source": "/((?!api/|assets/|static/|favicon.ico|manifest.json|logo.png|bookmark_logo.png|robots.txt|sitemap.xml).*)", "destination": "/index.html" }
  ]
}

