{
  "version": 2,
  "name": "aura-stable-final",
  "trailingSlash": false,
  "buildCommand": "npm install --prefix 3_code/frontend && npm run build --prefix 3_code/frontend",
  "outputDirectory": "3_code/frontend/dist",
  "installCommand": "echo done",
  "functions": {
    "api/core/index.py": {
      "maxDuration": 300
    },
    "api/swarm/index.py": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/swarm/:path*", "destination": "/api/swarm/index.py" },
    { "source": "/api/:path*",       "destination": "/api/core/index.py" },
    { "source": "/((?!api/).*)",     "destination": "/index.html" }
  ]
}
