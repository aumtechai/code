{
  "version": 2,
  "name": "aura-stable-final",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/core/index.py"
    },
    {
      "src": "/api/swarm/(.*)",
      "dest": "api/swarm/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "/index.html"
    }
  ],
  "build": {
    "env": {
      "ENABLE_UV": "0"
    }
  }
}
