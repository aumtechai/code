{
  "version": 2,
  "name": "aura-stable-final",
  "cleanUrls": true,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/swarm/(.*)", "destination": "/api/swarm/index" },
    { "source": "/api/(.*)",      "destination": "/api/core/index" },
    { "source": "/(.*)",          "destination": "/index.html" }
  ]
}
