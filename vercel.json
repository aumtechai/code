{
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/api/aura/(.*)", "dest": "api/swarm/index.py" },
    { "src": "/api/(.*)",      "dest": "api/core/index.py" },
    { "src": "/academic",      "dest": "/3_code/prepnex_app/roadmap.html" },
    { "src": "/vesta",         "dest": "/3_code/prepnex_app/vesta.html" },
    { "src": "/strategy",      "dest": "/3_code/prepnex_app/strategy.html" },
    { "src": "/(.*)",          "dest": "/$1" }
  ]
}
