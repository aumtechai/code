{
  "version": 2,
  "name": "aura-stable-final",
  "builds": [
    {
      "src": "api/core/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/swarm/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "api/core/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/core/index.py"
    },
    {
      "src": "/api/swarm/(.*)",
      "dest": "api/swarm/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "/index.html"
    }
  ]
}
