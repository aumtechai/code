platform :ios do
  desc "Push a new release build to the App Store (TestFlight)"
  lane :release do
    # 1. Provide the App Store Connect API Key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
      duration: 1200,
      in_house: false
    )

    # 2. Get the certificates and profiles automatically
    get_certificates           # Accesses Apple to get Distribution Cert
    get_provisioning_profile(  # Accesses Apple to get App Store Profile
      app_identifier: "com.studentsuccess.navigator",
      force: true
    )

    # 3. Build the app
    build_app(
      project: "frontend/ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      output_directory: "output",
      output_name: "App.ipa",
      export_team_id: ENV["APPLE_TEAM_ID"]
    )

    # 4. Upload to TestFlight
    upload_to_testflight
  end
end
