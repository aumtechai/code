default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :release do
    setup_ci

    key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"]
    is_base64 = key_content ? !key_content.include?("-----BEGIN") : true

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: key_content,
      is_key_content_base64: is_base64,
      in_house: false
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "ios/App/App.xcodeproj"
    )

    # Write the API Key to a temporary .p8 file for xcodebuild auth
    key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"]
    key_path = File.expand_path("AuthKey.p8")
    
    # Handle base64 or raw PEM
    if key_content && !key_content.include?("-----BEGIN")
      require 'base64'
      File.write(key_path, Base64.decode64(key_content))
    else
      File.write(key_path, key_content)
    end
    
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      export_team_id: ENV["APPLE_TEAM_ID"],
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyID #{ENV['APP_STORE_CONNECT_KEY_ID']}",
        "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_ISSUER_ID']}",
        "-authenticationKeyPath #{key_path}",
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}"
      ].join(" ")
    )

    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end
