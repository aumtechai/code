default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :release do
    setup_ci

    key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"]
    is_base64 = key_content ? !key_content.include?("-----BEGIN") : true

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: key_content,
      is_key_content_base64: is_base64,
      in_house: false
    )

    update_project_team(
      path: "ios/App/App.xcodeproj",
      teamid: ENV["APPLE_TEAM_ID"]
    )
    
    get_certificates(
      keychain_path: "#{lane_context[:KEYCHAIN_PATH]}-db",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
    )
    
    get_provisioning_profile(
      app_identifier: "com.studentsuccess.navigator",
      team_id: ENV["APPLE_TEAM_ID"]
    )
    
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      xcargs: ENV["APPLE_TEAM_ID"] ? "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}" : "-allowProvisioningUpdates"
    )

    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end
